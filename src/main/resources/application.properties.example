# Template di configurazione. Copiare in "application.properties" e inserire i valori reali.

# ===============================
# CONFIGURAZIONE DATABASE POSTGRES
# ===============================
spring.datasource.url=jdbc:postgresql://localhost:5432/ndovado_db
spring.datasource.username=postgres
spring.datasource.password=LA_TUA_PASSWORD_POSTGRES
spring.datasource.driver-class-name=org.postgresql.Driver
logging.level.org.springframework.jdbc.core=DEBUG
logging.level.org.springframework.jdbc=DEBUG
logging.level.org.springframework.transaction=TRACE

# ===============================
# API KEYS ESTERNE
# ===============================
gemini.api.key=LA_TUA_CHIAVE_GEMINI
# Mappa: OpenStreetMap (nessuna chiave API richiesta)

# ===============================
# EMAIL (Gmail SMTP)
# ===============================
# Credenziali SMTP: usare una App Password Google (non la password dell'account)
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=tua-email@gmail.com
spring.mail.password=LA_TUA_APP_PASSWORD_GMAIL
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true

# URL frontend (usato nei link delle email)
app.frontend.url=http://localhost:4200

# ===============================
# SPRING MVC / UPLOAD FILE
# ===============================
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
